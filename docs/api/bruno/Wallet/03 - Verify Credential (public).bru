meta {
  name: Verify Credential (public)
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/wallet/verify
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "jwt": "REPLACE_WITH_VC_JWT"
  }
}

docs {
  Public (AllowAnonymous) — T-WAL-2. Verifies a presented VC-JWT's RS256 signature against the
  issuer's own key, expiry, and revocation status. Always returns 200; check `data.isValid` and
  `data.reason` rather than the HTTP status.
}
