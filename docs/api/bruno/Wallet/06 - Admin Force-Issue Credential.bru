meta {
  name: Admin - Force-Issue Credential
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/admin/wallet/credentials/issue
  body: json
  auth: bearer
}

auth:bearer {
  token: {{admin_access_token}}
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "accountId": "{{account_id}}"
  }
}

docs {
  IdentityReviewer. Manual re-issue outside the normal approval-triggered flow — for testing
  or recovery. The account must already be Approved.
}
