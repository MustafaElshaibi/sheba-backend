meta {
  name: Get My Credentials
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/wallet/credentials
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  CitizenOnly. Lists all W3C Verifiable Credentials for the caller with decoded JWT-VC claims.
  A DigitalIdentityCredential is auto-issued on identity approval.
}
