meta {
  name: Get Credential Detail
  type: http
  seq: 2
}

get {
  url: {{baseUrl}}/api/wallet/credentials/REPLACE_WITH_CREDENTIAL_ID
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  CitizenOnly, ownership-checked (404 for a credential you don't own). Single-item detail —
  same shape as one item of "Get My Credentials".
}
