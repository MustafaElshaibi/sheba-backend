meta {
  name: Token - client_credentials (ministry)
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/connect/token
  body: formUrlEncoded
  auth: none
}

headers {
  Content-Type: application/x-www-form-urlencoded
}

body:form-urlencoded {
  grant_type: client_credentials
  client_id: sheba-api-internal
  client_secret: sheba-api-internal-dev-secret
  scope: ministry_api
}
