meta {
  name: Get Request by ID
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/requests/{{request_id}}
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Any authenticated principal — ownership enforced in the handler (own requests only, unless
  admin). Includes full RequestStepExecution history.
}
