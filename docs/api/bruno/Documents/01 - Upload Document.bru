meta {
  name: Upload Document
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/documents
  body: multipartForm
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

body:multipart-form {
  file: @file(REPLACE_WITH_LOCAL_FILE_PATH)
  documentType: PHOTO
}

docs {
  Accepted types: JPEG, PNG, WebP, PDF. Max size: 10 MB. Antiforgery disabled for this route
  (bearer-token auth, not cookie auth). documentType defaults to GENERAL if omitted.
}
