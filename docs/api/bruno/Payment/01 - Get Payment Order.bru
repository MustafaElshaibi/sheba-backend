meta {
  name: Get Payment Order
  type: http
  seq: 1
}

get {
  url: {{baseUrl}}/api/payments/REPLACE_WITH_PAYMENT_ORDER_ID
  body: none
  auth: bearer
}

auth:bearer {
  token: {{access_token}}
}

docs {
  Any authenticated principal; ownership enforced in the handler (a citizen sees only their own
  order; admins see any).
}
